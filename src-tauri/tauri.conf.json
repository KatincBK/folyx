{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Folyx",
  "version": "0.1.0",
  "identifier": "com.folyx.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Folyx",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": "default-src 'self'; media-src 'self' asset: http://asset.localhost https://asset.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxNjA4Mjk0OUE3RTY1QzMKUldURFpYNmFsSUpnOGZaK0pKOUh2UURQekQ5Z0lhQjRuUDM2bENreDVRK013Qjd1WU01SktZWXkK",
      "endpoints": [
        "https://github.com/KatincBK/folyx/releases/latest/download/latest.json"
      ]
    }
  }
}
